VITE_GAME_KIT_PROJECT_ID=mygame
VITE_GAME_KIT_ENV=QA
VITE_POSTHOG_API_KEY=

# Base URL for embed bundles (config.json, game.json) fetched in embedded mode
VITE_EMBED_STORAGE_URL=

# -----------------------------------------------------------------------------
# @wolfgames/components dev overrides (LOCAL ONLY — put these in .env.local)
#
# Both flags are read by vite.config.ts and ignored during production builds.
# `.env.local` is gitignored so they never accidentally ship.
#
#   VITE_COMPONENTS_LOCAL=1   Resolve from sibling repo ../game-components/
#                             instead of node_modules. Use when iterating on
#                             game-components in this monorepo.
#
#   VITE_COMPONENTS_SOURCE=1  Resolve from raw src/ instead of compiled dist/.
#                             Use for HMR straight off .ts source — no rebuild
#                             needed after each change.
#
# Fastest inner loop:
#   echo 'VITE_COMPONENTS_LOCAL=1' >> .env.local
#   echo 'VITE_COMPONENTS_SOURCE=1' >> .env.local
#   bun run dev
# -----------------------------------------------------------------------------
# VITE_COMPONENTS_LOCAL=
# VITE_COMPONENTS_SOURCE=
